# ============================================================
# PhishForge AI — Environment Variables
# Copy this file to .env.local and fill in all values
# NEVER commit .env.local to version control
# ============================================================

# ─── AI — OpenRouter (Primary Provider) ──────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-chat-v3-0324
# Site info for OpenRouter ranking (optional but recommended)
OPENROUTER_SITE_URL=https://phishforge.ai
OPENROUTER_SITE_NAME=PhishForge AI

# ─── AI — Ollama (Secondary / Local Provider) ────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# ─── AI Provider Configuration ───────────────────────────────
# Options: "openrouter" | "ollama"
DEFAULT_AI_PROVIDER=openrouter

# ─── Database — Supabase ─────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Next.js public env (accessible in browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Vector Database — Pinecone ──────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX=phishforge-knowledge
PINECONE_ENVIRONMENT=us-east-1

# ─── Authentication ───────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-256-bit-secret
JWT_EXPIRES_IN=7d
NEXTAUTH_SECRET=change-this-to-another-random-secret
NEXTAUTH_URL=http://localhost:3000

# ─── OAuth Providers ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Billing — Stripe ────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# ─── Application URLs ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Feature Flags ───────────────────────────────────────────
NEXT_PUBLIC_ENABLE_OLLAMA=true
NEXT_PUBLIC_ENABLE_BILLING=true

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_GENERATE=30
RATE_LIMIT_VALIDATE=60
WEBHOOK_TIMEOUT_MS=5000
GDPR_RETENTION_DAYS=365

# ─── Observability ────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
LOG_LEVEL=info

# ─── Infrastructure ──────────────────────────────────────────
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_TAG=latest
REDIS_URL=redis://localhost:6379
